# Example environment variables for local development and CI/CD configuration.
# Do NOT commit your actual secrets to a public repository.

# Docker Hub Username for pushing images
# Used in .github/workflows/go-ci.yml as ${{ secrets.DOCKER_USERNAME }}
DOCKER_USERNAME="your-dockerhub-username"

# Docker Hub Password/Personal Access Token for pushing images
# Used in .github/workflows/go-ci.yml as ${{ secrets.DOCKER_PASSWORD }}
DOCKER_PASSWORD="your-dockerhub-password-or-token"

# Kubernetes Kubeconfig for Staging environment
# Used in .github/workflows/go-ci.yml as ${{ secrets.KUBE_CONFIG_STAGING }}
# This should be the base64 encoded content of your kubeconfig file for staging.
KUBE_CONFIG_STAGING="your-base64-encoded-kubeconfig-for-staging"

# Kubernetes Kubeconfig for Production environment
# Used in .github/workflows/go-ci.yml as ${{ secrets.KUBE_CONFIG_PROD }}
# This should be the base64 encoded content of your kubeconfig file for production.
KUBE_CONFIG_PROD="your-base64-encoded-kubeconfig-for-production"

# Docker Repository for the GoTerminal application
# Used in .github/workflows/go-ci.yml
DOCKER_REPO="your-dockerhub-username/goterminal-app"